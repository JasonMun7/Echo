{
  "name": "echo-desktop",
  "version": "0.1.3",
  "description": "Echo Desktop — AI-powered voice and agent desktop client",
  "author": "Echo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/JasonMun7/Echo.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "generate-icon": "node scripts/generate-icon.mjs",
    "dist": "pnpm run generate-icon && electron-vite build && electron-builder --publish always",
    "dist:mac": "pnpm run generate-icon && electron-vite build && electron-builder --mac --publish always",
    "dist:win": "pnpm run generate-icon && electron-vite build && electron-builder --win --publish always",
    "pack": "pnpm run generate-icon && electron-vite build && electron-builder --dir",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@echo/types": "workspace:*",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tabler/icons-react": "^3.37.1",
    "@tailwindcss/postcss": "^4",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "livekit-client": "^2.17.2",
    "lucide-react": "^0.575.0",
    "motion": "^12.35.2",
    "ogl": "^1.0.11",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "use-stick-to-bottom": "^1.1.3",
    "ws": "^8.18.0",
    "zustand": "^5.0.2",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "shadcn": "^4.0.5",
    "typescript": "^5",
    "vite": "^5.0.0"
  }
}
