# Echo Mobile — Environment Variables
#
# You should NOT need this file. The mobile app reads from Doppler
# via `doppler run` (same vars as the web frontend).
#
# Run: pnpm dev:mobile  (from the echo/ root)
#
# Only use EXPO_PUBLIC_* overrides if the mobile app needs
# different values than the web app:
#
# EXPO_PUBLIC_API_URL=http://localhost:8000
# EXPO_PUBLIC_ECHO_AGENT_URL=http://localhost:8081
# EXPO_PUBLIC_FIREBASE_API_KEY=...
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=...
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=...
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=...
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
# EXPO_PUBLIC_FIREBASE_APP_ID=...
