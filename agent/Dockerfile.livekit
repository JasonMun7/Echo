# Echo Prism LiveKit Agent — Cloud Run (long-running worker)
# Build context: repo root (.)
FROM python:3.11-slim

WORKDIR /app

RUN mkdir -p /app/agent && touch /app/agent/__init__.py

COPY agent/requirements.txt /app/requirements.txt
COPY agent/echo_prism_agent /app/agent/echo_prism_agent
COPY scripts/run-livekit-with-health.py /app/scripts/run-livekit-with-health.py

RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 8080
ENV PORT=8080

CMD ["python", "/app/scripts/run-livekit-with-health.py"]
