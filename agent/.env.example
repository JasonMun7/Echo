# Echo Prism agent — use Doppler in dev/prd, or copy to .env for local tools (e.g. LangGraph CLI).
# Full list: scripts/doppler-env-reference.md

OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Gemini — synthesis defaults to ``gemini-3-flash-preview`` in ``echo_prism_agent/constants.py`` (override here).
# ECHOPRISM_SYNTHESIS_MODEL=gemini-3.1-pro-preview
# Video keyframe extraction: max frames, sample rate, skip head; max width before resize (libswscale-friendly).
# ECHOPRISM_SYNTHESIS_VIDEO_MAX_FRAMES=24
# ECHOPRISM_SYNTHESIS_VIDEO_FPS_SAMPLE=0.6
# ECHOPRISM_SYNTHESIS_VIDEO_SKIP_INITIAL_S=0.5
# ECHOPRISM_VIDEO_FRAME_MAX_WIDTH=1920

# Composio (workflow api_call, chat tools) — same API key as echo-backend
COMPOSIO_API_KEY=
# Default 1: allow manual tool execute without pinning COMPOSIO_TOOLKIT_VERSION_* (Composio SDK).
# Set to 0 if you pin toolkit versions in env for reproducible runs.
# COMPOSIO_DANGEROUSLY_SKIP_TOOLKIT_VERSION_CHECK=1

# Langfuse (optional — Composio + HITL spans; needs LANGFUSE_SECRET_KEY to enable)
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# Optional: comma-separated toolkits for bounded chat tool list (default in genai_tools.py)
# COMPOSIO_CHAT_TOOLKITS=slack,github,googlecalendar
# COMPOSIO_CHAT_TOOL_LIMIT=20

# GUI inference — UI-TARS via OpenRouter (same pattern as UI-TARS-desktop ``UITarsModel``)
# UI_TARS_MODEL_ID=bytedance/ui-tars-1.5-7b
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ECHOPRISM_OPENROUTER_TEMPERATURE=0
# ECHOPRISM_OPENROUTER_TOP_P=0.7
# ECHOPRISM_OPENROUTER_MAX_TOKENS=2048
# Match UI-TARS-desktop: model outputs coords on the VLM canvas; Echo maps to 0–1000 for operators.
# ECHOPRISM_UI_TARS_COORD_MODE=vlm_pixel   # default for ui-tars-1.5; use norm1000 for legacy 0–1000 output
# ECHOPRISM_UI_TARS_PROMPT=v15            # optional: force v1.5 prompt (auto when UI_TARS_MODEL_ID contains ui-tars-1.5)

# Optional: Kimi + muscle-mem (pip install -e ../muscle-mem-agent) — not used by default GUI path
# ECHOPRISM_MUSCLE_MODEL=moonshotai/kimi-k2.5
# ECHOPRISM_VERIFICATION_BUDGET=12

# GCS + Firebase Admin (Firestore, Storage) — same as backend
ECHO_GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
