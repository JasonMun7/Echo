# Echo Prism agent — use Doppler in dev/prd, or copy to .env for local tools (e.g. LangGraph CLI).
# Full list: scripts/doppler-env-reference.md

OPENROUTER_API_KEY=
GEMINI_API_KEY=

# GUI inference — UI-TARS via OpenRouter (same pattern as UI-TARS-desktop ``UITarsModel``)
# UI_TARS_MODEL_ID=bytedance/ui-tars-1.5-7b
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ECHOPRISM_OPENROUTER_TEMPERATURE=0
# ECHOPRISM_OPENROUTER_TOP_P=0.7
# ECHOPRISM_OPENROUTER_MAX_TOKENS=2048
# Match UI-TARS-desktop: model outputs coords on the VLM canvas; Echo maps to 0–1000 for operators.
# ECHOPRISM_UI_TARS_COORD_MODE=vlm_pixel   # default for ui-tars-1.5; use norm1000 for legacy 0–1000 output
# ECHOPRISM_UI_TARS_PROMPT=v15            # optional: force v1.5 prompt (auto when UI_TARS_MODEL_ID contains ui-tars-1.5)

# Optional: Kimi + muscle-mem (pip install -e ../muscle-mem-agent) — not used by default GUI path
# ECHOPRISM_MUSCLE_MODEL=moonshotai/kimi-k2.5
# ECHOPRISM_VERIFICATION_BUDGET=12

# GCS + Firebase Admin (Firestore, Storage) — same as backend
ECHO_GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# Auth0 Token Vault (same vars as backend — required on the agent process for api_call / Token Vault)
# Without these, federated token exchange cannot run; set ECHO_INTEGRATIONS_TOKEN_VAULT_ONLY=0 only if
# you still use legacy users/{uid}/integrations/{id} OAuth tokens.
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# Optional: M2M app for GET .../users/{id}/connected-accounts (Integrations debug button on web)
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=
# AUTH0_AUDIENCE=
# Optional backend: AUTH0_VAULT_AUTHORIZE_OMIT_AUDIENCE=1 — omit audience on Connect (vault) authorize only
# Optional backend: AUTH0_VAULT_CALLBACK_URL=https://.../api/auth0/connect/callback — match auth0-fastapi sample
# Optional backend: AUTH0_VAULT_USE_MY_ACCOUNT_CONNECT=0 — disable My Account connected-accounts Connect (default is on)
# Optional backend: AUTH0_LINK_CONNECTION=google-oauth2 — force Link Auth0 to a specific connection (omit for Universal Login default)
# AUTH0_TOKEN_VAULT=1
# ECHO_INTEGRATIONS_TOKEN_VAULT_ONLY=1  # default: Auth0 Token Vault only; set 0 to allow legacy Firestore OAuth tokens
