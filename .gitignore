# =============================================================================
# Echo — Monorepo .gitignore
# Covers: Next.js web, Electron desktop, FastAPI backend, pnpm workspace
# Industry-standard patterns + project-specific exclusions.
# =============================================================================

# -----------------------------------------------------------------------------
# Node / pnpm
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
.pnp
.pnp.*
.pnpm-store/
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json
**/package-lock.json
jspm_packages/
web_modules/

# -----------------------------------------------------------------------------
# Next.js (apps/web)
# -----------------------------------------------------------------------------
.next/
/.next/
apps/web/.next/
apps/web/out/
apps/web/next-env.d.ts
next-env.d.ts

# -----------------------------------------------------------------------------
# Electron (apps/desktop)
# -----------------------------------------------------------------------------
apps/desktop/out/
apps/desktop/dist/

# -----------------------------------------------------------------------------
# TypeScript / build artifacts
# -----------------------------------------------------------------------------
*.tsbuildinfo
**/*.tsbuildinfo
packages/*/dist/
dist/
build/

# -----------------------------------------------------------------------------
# Python / Backend
# -----------------------------------------------------------------------------
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
backend/.venv/
backend/agent/.venv/
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.dmypy.json
.dmypy.json.*
.ruff_cache/
.pytype/
.nox/
htmlcov/
.coverage
coverage.xml
*.cover
.hypothesis/
*.manifest

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit real env files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!apps/web/.env.local.example
!backend/.env.example
.envrc

# shadcn/registry config (may contain Aceternity API token)
apps/web/components.json

# Credentials & service account keys
backend/service-account.json
*service-account*.json
*credentials*.json
*.pem
*.key

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
/coverage
**/.coverage
**/coverage/
# Playwright
tests/playwright-report/
tests/test-results/
playwright-report/
test-results/
blob-report/
.nyc_output/

# -----------------------------------------------------------------------------
# Linting / formatting cache
# -----------------------------------------------------------------------------
.eslintcache
.stylelintcache

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Cursor IDE (project-specific config; optional to share via separate rule files)
# -----------------------------------------------------------------------------
.cursor/
.cursorignore

# -----------------------------------------------------------------------------
# Deployment / hosting
# -----------------------------------------------------------------------------
.vercel
.vercel/
.firebase/
firebase-debug.log
firebase-debug.*.log
*.firebase/
firebase/
docs/

# -----------------------------------------------------------------------------
# Monorepo / tooling
# -----------------------------------------------------------------------------
.turbo/
.cache/
.parcel-cache/
.serverless/

# -----------------------------------------------------------------------------
# Jupyter / notebooks (if any)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.tgz
*.tar.gz
.npm
.yarn-integrity
