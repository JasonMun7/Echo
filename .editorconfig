# Echo — EditorConfig (https://editorconfig.org)
# Use with your editor's EditorConfig plugin for consistent style across the repo.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,mjs,cjs,vue,css,scss,html,json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{sh,bash}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
